    "@vsn/db": "*",
    "@vsn/types": "*",
    "aws-jwt-verify": "^5.1.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.6",
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.25.9",
    "tsx": "^4.20.5"
  }
